<Window x:Class="DeployMonitor.Views.AccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="웹 계정 설정"
        Height="280" Width="380"
        MinHeight="260" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="웹 대시보드 로그인 계정을 변경합니다."
                   Foreground="Gray" FontSize="12" Margin="0,0,0,12"/>

        <!-- Username -->
        <TextBlock Grid.Row="1" Text="아이디" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="UsernameBox" Padding="4,3" Margin="0,0,0,8"/>

        <!-- Password -->
        <TextBlock Grid.Row="3" Text="비밀번호 (4자 이상)" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" Padding="4,3" Margin="0,0,0,8"/>

        <!-- Status -->
        <TextBlock Grid.Row="5" x:Name="StatusText" Foreground="Gray" FontSize="12"
                   TextWrapping="Wrap" VerticalAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="저장" Width="70" Padding="4,4" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="닫기" Width="70" Padding="4,4" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
