<Window x:Class="DeployMonitor.Views.WhitelistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exited(0) Whitelist"
        Height="400" Width="380"
        MinHeight="300" MinWidth="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input Row -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" Grid.Column="0" Padding="4,3" Margin="0,0,4,0"
                     KeyDown="InputBox_KeyDown" ToolTip="키워드 입력 후 Enter 또는 Add 클릭"/>
            <Button Grid.Column="1" Content="Add" Width="50" Padding="4,3" Click="AddButton_Click"/>
        </Grid>

        <!-- List -->
        <ListBox x:Name="ItemsList" Grid.Row="1" BorderBrush="LightGray" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" Padding="4,2"/>
                        <Button Grid.Column="1" Content="X" Width="24" Height="22"
                                FontSize="11" Padding="0" Margin="4,0,0,0"
                                Tag="{Binding}" Click="RemoveButton_Click"
                                ToolTip="삭제"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Help text -->
        <TextBlock Grid.Row="2" Text="비어 있으면 모든 Exited(0) 컨테이너를 허용합니다."
                   Foreground="Gray" FontSize="11" Margin="0,6,0,4"/>

        <!-- Close button -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Width="70" Padding="4,4" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
